{
  "name": "Mythpen",
  "private": true,
  "version": "0.0.3",
  "author": "Nico",
  "license": "CC BY-NC-SA 4.0",
  "packageManager": "pnpm@10.10.0",
  "pnpm": {},
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niyongsheng/mythpen.git"
  },
  "bugs": {
    "url": "https://github.com/niyongsheng/mythpen/issues"
  },
  "homepage": "https://github.com/niyongsheng/mythpen#readme",
  "scripts": {
    "dev": "vite",
    "seed": "node server/seed.js",
    "dev:server": "nodemon --watch server server/index.js",
    "dev:all": "node server/seed.js && concurrently -k \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "lint": "biome check --write src/",
    "format": "biome format --write src/",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "build:sidecar": "bun build --compile --assets node_modules/sql.js/dist/sql-wasm.wasm ./server/index.js --outfile src-tauri/binaries/mythpen-server"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "cors": "^2.8.6",
    "epub-gen": "^0.1.0",
    "express": "^5.2.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.13.0",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.14",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
